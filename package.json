{
  "name": "conduit-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "clean": "pnpm -r clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "pnpm --filter @conduit/docs dev",
    "docs:build": "pnpm --filter @conduit/docs build",
    "extension:dev": "pnpm --filter @conduit/extension dev",
    "extension:build": "pnpm --filter @conduit/extension build",
    "extension:package": "pnpm --filter @conduit/extension package",
    "daemon:start": "pnpm --filter @conduit/daemon start",
    "daemon:dev": "pnpm --filter @conduit/daemon dev",
    "mcp:start": "pnpm --filter @conduit/mcp-server start",
    "conduit:doctor": "node packages/cli/bin/doctor.js"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2"
  }
}
